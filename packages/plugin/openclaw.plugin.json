{
  "id": "kyaclaw-security",
  "name": "KyaClaw PRISM Security Guard",
  "description": "Proactive Runtime Injection Shield & Monitor — tool abuse, prompt injection, and outbound data exfiltration defense.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "riskTtlMs": { "type": "integer", "minimum": 1000, "default": 180000 },
      "maxScanChars": { "type": "integer", "minimum": 256, "default": 20000 },
      "scanTools": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["web_fetch", "browser"]
      },
      "protectedPathPatterns": {
        "type": "array",
        "items": { "type": "string" },
        "default": [
          "/etc/*", "/root/*", "/home/*/.ssh/*", "*.env",
          "openclaw.json", "AGENTS.md", "SOUL.md", "auth-profiles.json"
        ]
      },
      "execAllowedPrefixes": {
        "type": "array",
        "items": { "type": "string" },
        "default": [
          "node", "npm", "npx", "bun", "bunx", "python3", "python", "pip",
          "git", "gh", "ls", "cat", "head", "tail", "wc", "grep", "find", "which",
          "echo", "date", "pwd", "docker", "openclaw"
        ]
      },
      "execBlockedPatterns": {
        "type": "array",
        "items": { "type": "string" },
        "default": [
          "rm\\s+-rf\\s+/(\\s|$)",
          "curl\\s+[^|]*\\|\\s*(sh|bash|zsh)",
          "wget\\s+[^|]*\\|\\s*(sh|bash|zsh)",
          "nc\\s+.*\\s+-e\\s+",
          "\\b(sh|bash|zsh)\\s+-c\\b",
          "python\\s+-c\\s+.*(socket|subprocess)",
          "node\\s+-e\\s+.*(child_process|net\\.)",
          "git\\s+-c\\s+[^\\s]*sshcommand\\s*=",
          "\\bsudo\\b", ">\\/etc\\/", ">\\.ssh\\/"
        ]
      },
      "scannerUrl": { "type": "string", "default": "http://127.0.0.1:18766/scan" },
      "scannerTimeoutMs": { "type": "integer", "minimum": 50, "default": 900 },
      "blockOnScannerFailure": { "type": "boolean", "default": false },
      "outboundSecretPatterns": {
        "type": "array",
        "items": { "type": "string" },
        "default": [
          "AKIA[0-9A-Z]{16}",
          "-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY-----",
          "xox[baprs]-[0-9A-Za-z-]{10,}",
          "ghp_[0-9A-Za-z]{30,}",
          "sk-[A-Za-z0-9]{20,}"
        ]
      }
    }
  }
}
